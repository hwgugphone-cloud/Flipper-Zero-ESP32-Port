App(
    appid="qflipper",
    name="qFlipper",
    apptype=FlipperAppType.APP,
    entry_point="qflipper_app",
    requires=[
        "gui",
    ],
    # Generous stack: qflipper_enter calls furi_hal_usb_composite_install
    # which on ESP32-S3 runs the deep TinyUSB / esp_tinyusb init chain.
    stack_size=8192,
    icon="A_Plugins_14",
    order=96,
    sources=["qflipper.c"],
)
